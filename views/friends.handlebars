<h1>Friends</h1>

{{#if pending}}
<h2>Pending Requests</h2>
{{#each pending}}
<div>
  <p>Friend request from {{this.firstName}} {{this.lastName}}</p>
  <form method="POST" action="/friends/accept/{{this._id}}">
    <button type="submit">Accept</button>
  </form>
  <form method="POST" action="/friends/decline/{{this._id}}">
    <button type="submit">Decline</button>
  </form>
</div>
{{/each}}
{{/if}}

<h2>My Friends</h2>
{{#if friendsList}}
{{#each friendsList}}
<div>
  <p>{{this.firstName}} {{this.lastName}}</p>
  {{#if this.recentPlan}}
  <p>Latest plan: <a href="/plans/{{this.recentPlan._id}}">{{this.recentPlan.title}}</a> - {{this.recentPlan.date}}</p>
  {{else}}
  <p>No public plans yet</p>
  {{/if}}
</div>
{{/each}}
{{else}}
<p>No friends yet</p>
{{/if}}