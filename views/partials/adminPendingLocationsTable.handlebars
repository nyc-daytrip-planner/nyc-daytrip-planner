<section class="admin-pending-locations">
  <header class="admin-section-header">
    <h2>Pending Locations <span class="admin-count">({{pending.length}})</span></h2>
  </header>

  {{#if pending.length}}
    <table class="admin-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Type</th>
          <th>Address</th>
          <th>Submitted by</th>
          <th>Submitted at</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        {{#each pending}}
          <tr data-location-id="{{this._id}}">
            <td><a href="/explore/{{this._id}}">{{this.name}}</a></td>
            <td>{{this.type}}</td>
            <td class="cell-text">{{this.address}}</td>
            <td>{{this.submitterEmail}}</td>
            <td>{{this.createdAtDisplay}}</td>
            <td>
              <button type="button" class="admin-approve-btn">Approve</button>
              <button type="button" class="admin-delete-btn admin-reject-btn">Reject</button>
            </td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  {{else}}
    <p class="admin-empty">No pending locations.</p>
  {{/if}}
</section>
